# Copy this file to .env.local and fill in real values.
# Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouteService distance API (server-side only)
# Provide your API key in .env.local; do NOT commit real keys here.
ORS_API_KEY=

# Upstash Redis rate limiting (required in production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional demo data switch
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
